# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:STRONG_PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://your_db_user:your_strong_password@127.0.0.1:5432/society_manager

# ── Node environment ──────────────────────────────────────────────────────────
# Set to "production" on the live server — NEVER "development" in prod
NODE_ENV=production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# All three must be different, minimum 32 random hex characters each
JWT_SECRET_KEY=REPLACE_WITH_CRYPTO_RANDOM_64_CHAR_HEX
JWT_ACCESS_SECRET=REPLACE_WITH_CRYPTO_RANDOM_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_CRYPTO_RANDOM_64_CHAR_HEX

# ── JWT expiry ────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS (comma-separated list of allowed frontend origins) ───────────────────
# Example: https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=https://app.yourdomain.com

# ── Redis (required in production — rate limiting and OTP storage) ────────────
REDIS_URL=redis://localhost:6379

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Use a dedicated transactional service (SendGrid, Mailgun) in production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM_NAME=Society Management
SMTP_FROM_EMAIL=your_email@gmail.com

# ── WhatsApp Business API (Interakt / Meta WABA) ──────────────────────────────
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_URL=https://api.interakt.ai/v1/public/message/

# ── Firebase ──────────────────────────────────────────────────────────────────
# Paste the contents of firebase-service-account.json as a single minified JSON line
# Do NOT commit the actual firebase-service-account.json file
FIREBASE_SERVICE_ACCOUNT_JSON=
