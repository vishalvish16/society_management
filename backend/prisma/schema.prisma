generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  PRAMUKH
  CHAIRMAN
  VICE_CHAIRMAN
  SECRETARY
  ASSISTANT_SECRETARY
  TREASURER
  ASSISTANT_TREASURER
  MEMBER
  RESIDENT
  WATCHMAN
}

enum UnitStatus {
  OCCUPIED
  VACANT
  RENOVATION
}

enum OccupancyType {
  OWNER_OCCUPIED
  RENTED
  LEASED
  PARTIALLY_RENTED
  VACANT
}

enum AgreementType {
  RENT
  LEASE
  LICENSE
}

enum BillStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK
  UPI
  ONLINE
  RAZORPAY
}

enum LedgerAccount {
  CASH
  BANK
}

enum LedgerDirection {
  IN
  OUT
}

enum ExpenseCategory {
  MAINTENANCE
  UTILITIES
  EVENTS
  SECURITY
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VisitorStatus {
  PENDING
  VALID
  USED
  EXPIRED
}

enum WalkinApprovalStatus {
  AWAITING
  APPROVED
  DENIED
}

enum ScanResult {
  VALID
  INVALID
  EXPIRED
}

enum NotificationTargetType {
  UNIT
  ROLE
  ALL
}

enum NotificationType {
  BILL
  PAYMENT
  EXPENSE
  VISITOR
  ANNOUNCEMENT
  MANUAL
  COMPLAINT
  SUGGESTION
  DELIVERY
  DOMESTIC_HELP
  MOVE_IN_OUT
  AMENITY
  GATE_PASS
  PARKING
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum SocietyStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ComplaintStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintCategory {
  MAINTENANCE
  SECURITY
  CLEANLINESS
  NOISE
  PARKING
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

/// Duty shift for society staff (watchman, maintenance, etc.).
enum StaffShift {
  DAY
  NIGHT
  FULL
}

enum DomesticHelpType {
  MAID
  COOK
  DRIVER
  NURSE
  SWEEPER
  GARDENER
  OTHER
}

enum DomesticHelpStatus {
  ACTIVE
  SUSPENDED
  REMOVED
}

enum DeliveryStatus {
  PENDING
  ALLOWED
  DENIED
  COLLECTED
  RETURNED
  LEFT_AT_GATE
}

enum VehicleType {
  CAR
  TWO_WHEELER
  CYCLE
  OTHER
}

enum ParkingSlotType {
  COVERED
  OPEN
  BASEMENT
  VISITOR
  STILT
  RESERVED
}

enum ParkingSlotStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  UNDER_MAINTENANCE
  BLOCKED
}

enum ParkingAllotmentStatus {
  ACTIVE
  RELEASED
  TRANSFERRED
  SUSPENDED
}

enum ParkingChargeFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum ParkingSessionStatus {
  ACTIVE
  COMPLETED
  OVERSTAYED
}

enum AmenityStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
}

// FREE = no booking needed (temple etc.)
// SLOT = hourly/duration slots
// HALF_DAY = first-half / second-half / full-day
// MONTHLY = subscribe for N hrs/day per month
enum AmenityBookingType {
  FREE
  SLOT
  HALF_DAY
  MONTHLY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum GatePassStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

enum GatePassDecision {
  APPROVED
  REJECTED
}

enum MoveRequestType {
  MOVE_IN
  MOVE_OUT
}

enum MoveRequestStatus {
  PENDING
  DUES_CLEARED
  APPROVED
  REJECTED
  COMPLETED
}

enum ResidentType {
  OWNER
  TENANT
}

// ─── Models ──────────────────────────────────────────────────────────

model Plan {
  id           String    @id @default(uuid())
  name         String    @unique
  displayName  String
  priceMonthly Decimal   @db.Decimal(10, 2)
  priceYearly  Decimal   @db.Decimal(10, 2)
  pricePerUnit Decimal   @db.Decimal(10, 2)
  maxUnits     Int       @default(-1) // -1 = unlimited
  maxUsers     Int       @default(-1) // -1 = unlimited
  features     Json // e.g., ["CORE", "COMMUNICATION", "SECURITY", "OPERATIONS", "FINANCE", "ADMIN"]
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  societies    Society[]

  subscriptionPayments SubscriptionPayment[]

  @@map("plans")
}

model Society {
  id              String        @id @default(uuid())
  name            String
  address         String?
  city            String?
  logoUrl         String?
  contactEmail    String?
  contactPhone    String?
  planId          String
  plan            Plan          @relation(fields: [planId], references: [id])
  planStartDate   DateTime
  planRenewalDate DateTime
  planDuration    String?       @default("MONTHLY") // MONTHLY, THREE_MONTHS, SIX_MONTHS, YEARLY
  status          SocietyStatus @default(ACTIVE)
  settings        Json?
  // settings shape: { late_fee_type, late_fee_amount, due_day, qr_expiry_mins,
  //                   unit_prefix, gstin, gst_rate, gst_applicable,
  //                   amenity_approval_required, delivery_timeout_mins }
  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  users                    User[]
  units                    Unit[]
  expenses                 Expense[]
  visitors                 Visitor[]
  notifications            Notification[]
  notices                  Notice[]
  complaints               Complaint[]
  suggestions              Suggestion[]
  staff                    Staff[]
  subscriptionPayments     SubscriptionPayment[]
  domesticHelps            DomesticHelp[]
  deliveries               Delivery[]
  vehicles                 Vehicle[]
  parkingSlots             ParkingSlot[]
  parkingAllotments        ParkingAllotment[]
  parkingCharges           ParkingCharge[]
  parkingSessions          ParkingSession[]
  moveRequests             MoveRequest[]
  amenities                Amenity[]
  amenityBookings          AmenityBooking[]
  gatePasses               GatePass[]
  donations                Donation[]
  ledgerEntries            LedgerEntry[]
  societyGates             SocietyGate[]
  maintenanceBillSchedules MaintenanceBillSchedule[]
  chatRooms                ChatRoom[]
  polls                    Poll[]
  events                   Event[]
  rentalRecords            RentalRecord[]
  tasks                    Task[]
  societyRules             SocietyRule[]
  assets                   Asset[]

  @@map("societies")
}

/// Named entry points for a society (main gate, service gate, tower lobby, etc.).
model SocietyGate {
  id        String   @id @default(uuid())
  societyId String
  society   Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  name      String
  code      String? // optional short label, e.g. G1
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  staff     Staff[]

  @@unique([societyId, name])
  @@index([societyId])
  @@map("society_gates")
}

model DonationCampaign {
  id           String     @id @default(uuid())
  societyId    String
  title        String
  description  String?
  targetAmount Decimal?   @db.Decimal(10, 2)
  startDate    DateTime
  endDate      DateTime?
  isActive     Boolean    @default(true)
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  donations    Donation[]

  @@index([societyId])
  @@map("donation_campaigns")
}

model Donation {
  id            String            @id @default(uuid())
  societyId     String
  society       Society           @relation(fields: [societyId], references: [id])
  campaignId    String?
  campaign      DonationCampaign? @relation(fields: [campaignId], references: [id])
  donorId       String
  donor         User              @relation("MadeDonations", fields: [donorId], references: [id])
  amount        Decimal           @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  note          String?
  paidAt        DateTime          @default(now())
  createdAt     DateTime          @default(now())

  @@index([societyId])
  @@index([campaignId])
  @@map("donations")
}

// ── HIGH PRIORITY FEATURE MODELS ──────────────────────────────────────

model DomesticHelp {
  id             String             @id @default(uuid())
  societyId      String
  society        Society            @relation(fields: [societyId], references: [id])
  unitId         String
  unit           Unit               @relation(fields: [unitId], references: [id])
  registeredById String
  name           String
  type           DomesticHelpType
  phone          String?
  photoUrl       String?
  entryCode      String             @unique // 6-digit numeric
  status         DomesticHelpStatus @default(ACTIVE)
  allowedDays    Json? // [1,2,3,4,5] weekdays allowed
  allowedFrom    String? // "07:00"
  allowedTo      String? // "21:00"
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  logs           DomesticHelpLog[]

  @@index([societyId])
  @@index([entryCode])
  @@map("domestic_helps")
}

model DomesticHelpLog {
  id             String       @id @default(uuid())
  domesticHelpId String
  domesticHelp   DomesticHelp @relation(fields: [domesticHelpId], references: [id])
  unitId         String
  loggedById     String
  type           String // entry | exit
  loggedAt       DateTime     @default(now())

  @@index([domesticHelpId])
  @@map("domestic_help_logs")
}

model Delivery {
  id          String         @id @default(uuid())
  societyId   String
  society     Society        @relation(fields: [societyId], references: [id])
  unitId      String
  unit        Unit           @relation(fields: [unitId], references: [id])
  loggedById  String
  agentName   String
  company     String?
  description String?
  status      DeliveryStatus @default(PENDING)
  notifiedAt  DateTime?
  respondedAt DateTime?
  respondedBy String?
  collectedAt DateTime?
  collectedBy String?
  receivedAt  DateTime?
  receivedBy  String?
  receivedPhotoUrl String?
  returnedAt  DateTime?
  photoUrl    String?
  droppedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([societyId])
  @@index([status])
  @@map("deliveries")
}

model Vehicle {
  id             String      @id @default(uuid())
  societyId      String
  society        Society     @relation(fields: [societyId], references: [id])
  unitId         String
  unit           Unit        @relation(fields: [unitId], references: [id])
  registeredById String
  registeredBy   User        @relation("RegisteredVehicles", fields: [registeredById], references: [id])
  updatedById    String?
  updatedBy      User?       @relation("UpdatedVehicles", fields: [updatedById], references: [id], onDelete: SetNull)
  type           VehicleType
  numberPlate    String
  brand          String?
  model          String?
  colour         String?
  isActive       Boolean     @default(true)
  removedAt      DateTime?
  removedById    String?
  removedBy      User?       @relation("RemovedVehicles", fields: [removedById], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  allotments ParkingAllotment[]
  sessions   ParkingSession[]
  auditLogs  VehicleAuditLog[]

  @@unique([societyId, numberPlate])
  @@index([societyId])
  @@map("vehicles")
}

model VehicleAuditLog {
  id        String   @id @default(uuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  societyId String
  unitId    String
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  note      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([societyId])
  @@index([unitId])
  @@map("vehicle_audit_logs")
}

model ParkingSlot {
  id            String            @id @default(uuid())
  societyId     String
  society       Society           @relation(fields: [societyId], references: [id])
  slotNumber    String
  zone          String?
  floor         Int?
  type          ParkingSlotType
  status        ParkingSlotStatus @default(AVAILABLE)
  isHandicapped Boolean           @default(false)
  hasEVCharger  Boolean           @default(false)
  length        Float?
  width         Float?
  isActive      Boolean           @default(true)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  allotments ParkingAllotment[]
  sessions   ParkingSession[]
  charges    ParkingCharge[]

  @@unique([societyId, slotNumber])
  @@index([societyId, status])
  @@index([societyId, type])
  @@map("parking_slots")
}

model ParkingAllotment {
  id                  String                 @id @default(uuid())
  societyId           String
  society             Society                @relation(fields: [societyId], references: [id])
  slotId              String
  slot                ParkingSlot            @relation(fields: [slotId], references: [id])
  unitId              String
  unit                Unit                   @relation(fields: [unitId], references: [id])
  vehicleId           String?
  vehicle             Vehicle?               @relation(fields: [vehicleId], references: [id])
  allottedById        String
  status              ParkingAllotmentStatus @default(ACTIVE)
  startDate           DateTime               @default(now())
  endDate             DateTime?
  previousAllotmentId String?
  transferReason      String?
  releaseReason       String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  charges ParkingCharge[]

  @@index([societyId, status])
  @@index([slotId, status])
  @@index([unitId])
  @@index([vehicleId])
  @@map("parking_allotments")
}

model ParkingCharge {
  id            String                 @id @default(uuid())
  societyId     String
  society       Society                @relation(fields: [societyId], references: [id])
  slotId        String
  slot          ParkingSlot            @relation(fields: [slotId], references: [id])
  allotmentId   String?
  allotment     ParkingAllotment?      @relation(fields: [allotmentId], references: [id])
  unitId        String
  unit          Unit                   @relation(fields: [unitId], references: [id])
  amount        Decimal                @db.Decimal(10, 2)
  frequency     ParkingChargeFrequency
  dueDate       DateTime
  paidAt        DateTime?
  paymentMethod PaymentMethod?
  isPaid        Boolean                @default(false)
  description   String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([societyId, isPaid])
  @@index([unitId])
  @@map("parking_charges")
}

model ParkingSession {
  id             String               @id @default(uuid())
  societyId      String
  society        Society              @relation(fields: [societyId], references: [id])
  slotId         String
  slot           ParkingSlot          @relation(fields: [slotId], references: [id])
  vehicleId      String?
  vehicle        Vehicle?             @relation(fields: [vehicleId], references: [id])
  guestPlate     String?
  guestName      String?
  guestPhone     String?
  visitorId      String?
  deliveryId     String?
  linkedUnitId   String?
  linkedUnit     Unit?                @relation(fields: [linkedUnitId], references: [id])
  entryAt        DateTime             @default(now())
  exitAt         DateTime?
  expectedExitAt DateTime?
  entryById      String
  exitById       String?
  status         ParkingSessionStatus @default(ACTIVE)
  notes          String?

  @@index([societyId, status])
  @@index([slotId, status])
  @@map("parking_sessions")
}

model MoveRequest {
  id                 String            @id @default(uuid())
  societyId          String
  society            Society           @relation(fields: [societyId], references: [id])
  unitId             String
  unit               Unit              @relation(fields: [unitId], references: [id])
  requestedById      String
  type               MoveRequestType
  status             MoveRequestStatus @default(PENDING)
  residentName       String
  residentPhone      String
  residentEmail      String?
  residentType       ResidentType      @default(TENANT)
  rentalAgreementUrl String?
  idProofUrl         String?
  vehicleNumbers     Json?
  memberCount        Int?
  expectedDate       DateTime?
  pendingDues        Decimal?          @db.Decimal(10, 2)
  nocIssuedAt        DateTime?
  nocIssuedById      String?
  approvedAt         DateTime?
  approvedById       String?
  rejectionReason    String?
  completedAt        DateTime?
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([societyId])
  @@index([status])
  @@map("move_requests")
}

model Amenity {
  id              String             @id @default(uuid())
  societyId       String
  society         Society            @relation(fields: [societyId], references: [id])
  name            String
  description     String?
  capacity        Int?
  bookingType     AmenityBookingType @default(SLOT)
  // SLOT fields
  bookingDuration Int                @default(60) // minutes per slot
  openTime        String             @default("06:00")
  closeTime       String             @default("22:00")
  // HALF_DAY fields – firstHalfEnd marks the split (e.g. "13:00")
  firstHalfEnd    String?
  // MONTHLY fields – max hrs per day a single member can book
  maxDailyHours   Int?
  bookingFee      Decimal            @default(0) @db.Decimal(10, 2)
  halfDayFee      Decimal            @default(0) @db.Decimal(10, 2) // per half
  fullDayFee      Decimal            @default(0) @db.Decimal(10, 2)
  monthlyFee      Decimal            @default(0) @db.Decimal(10, 2)
  maxAdvanceDays  Int                @default(30)
  photoUrl        String?
  status          AmenityStatus      @default(ACTIVE)
  closurePeriods  Json? // [{from,to,reason}]
  rules           String?
  requireApproval Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  bookings        AmenityBooking[]

  @@index([societyId])
  @@map("amenities")
}

model AmenityBooking {
  id              String        @id @default(uuid())
  amenityId       String
  amenity         Amenity       @relation(fields: [amenityId], references: [id])
  societyId       String
  society         Society       @relation(fields: [societyId], references: [id])
  unitId          String
  unit            Unit          @relation(fields: [unitId], references: [id])
  bookedById      String
  bookedBy        User          @relation("AmenityBookings", fields: [bookedById], references: [id])
  // For SLOT / HALF_DAY bookings
  bookingDate     DateTime?     @db.Date
  startTime       String? // "09:00"
  endTime         String? // "10:00"
  // half_day slot: FULL | FIRST_HALF | SECOND_HALF
  halfDaySlot     String?
  // For MONTHLY bookings
  monthYear       String? // "2025-06"
  dailyHoursLimit Int?
  status          BookingStatus @default(PENDING)
  guestCount      Int?
  purpose         String?
  feeCharged      Decimal       @default(0) @db.Decimal(10, 2)
  paymentStatus   String?
  approvedById    String?
  approvedAt      DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([societyId])
  @@index([amenityId, bookingDate])
  @@map("amenity_bookings")
}

model GatePass {
  id              String         @id @default(uuid())
  societyId       String
  society         Society        @relation(fields: [societyId], references: [id])
  unitId          String
  unit            Unit           @relation(fields: [unitId], references: [id])
  createdById     String
  createdBy       User           @relation("CreatedGatePasses", fields: [createdById], references: [id])
  passCode        String         @unique // 8-char readable alphanumeric
  itemDescription String
  reason          String?
  validFrom       DateTime
  validTo         DateTime
  status          GatePassStatus @default(ACTIVE)
  scannedById     String?
  scannedBy       User?          @relation("ScannedGatePasses", fields: [scannedById], references: [id], onDelete: SetNull)
  scannedAt       DateTime?
  decision        GatePassDecision?
  decisionNote    String?
  notes           String?
  createdAt       DateTime       @default(now())
  logs            GatePassLog[]

  @@index([societyId])
  @@index([passCode])
  @@map("gate_passes")
}

model GatePassLog {
  id         String           @id @default(uuid())
  gatePassId String
  gatePass   GatePass         @relation(fields: [gatePassId], references: [id], onDelete: Cascade)
  scannedById String?
  scannedBy  User?            @relation(fields: [scannedById], references: [id], onDelete: SetNull)
  result     String           // VALID | EXPIRED | USED | CANCELLED | NOT_YET_VALID | INVALID
  decision   GatePassDecision?
  note       String?
  scannedAt  DateTime         @default(now())

  @@index([gatePassId])
  @@index([scannedById])
  @@map("gate_pass_logs")
}

model User {
  id                    String    @id @default(uuid())
  societyId             String? // NULL for super_admin
  society               Society?  @relation(fields: [societyId], references: [id])
  role                  UserRole
  name                  String
  email                 String?   @unique
  phone                 String
  passwordHash          String
  fcmToken              String?
  /// Public URL path served from /uploads/profiles/…
  profilePhotoUrl       String?
  dateOfBirth           DateTime? @db.Date
  /// Self-reported number of people living in the household (including the member).
  householdMemberCount  Int?
  bio                   String?
  emergencyContactName  String?
  emergencyContactPhone String?
  isActive              Boolean   @default(true)
  createdById           String?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  unitResidents        UnitResident[]
  bills                MaintenanceBill[]
  generatedBills       MaintenanceBill[]         @relation("GeneratedBills")
  deletedBills         MaintenanceBill[]         @relation("DeletedBills")
  billAuditLogs        BillAuditLog[]
  raisedComplaints     Complaint[]               @relation("RaisedBy")
  assignedComplaints   Complaint[]               @relation("AssignedTo")
  raisedSuggestions    Suggestion[]              @relation("RaisedSuggestions")
  assignedSuggestions  Suggestion[]              @relation("AssignedSuggestions")
  markedAttendance     StaffAttendance[]
  refreshTokens        RefreshToken[]
  submittedExpenses    Expense[]                 @relation("SubmittedExpenses")
  approvedExpenses     Expense[]                 @relation("ApprovedExpenses")
  invitedVisitors      Visitor[]                 @relation("InvitedVisitors")
  scannedLogs          VisitorLog[]              @relation("scannedLogs")
  createdGatePasses    GatePass[]                @relation("CreatedGatePasses")
  scannedGatePasses    GatePass[]                @relation("ScannedGatePasses")
  gatePassLogs         GatePassLog[]
  sentNotifications    Notification[]            @relation("sentNotifications")
  createdNotices       Notice[]                  @relation("createdNotices")
  staffProfile         Staff?
  donations            Donation[]                @relation("MadeDonations")
  amenityBookings      AmenityBooking[]          @relation("AmenityBookings")
  createdBillSchedules MaintenanceBillSchedule[]
  createdLedgerEntries LedgerEntry[]             @relation("LedgerEntryCreatedBy")
  chatMemberships      ChatRoomMember[]          @relation("ChatMemberships")
  sentMessages         ChatMessage[]             @relation("SentMessages")
  createdPolls         Poll[]                    @relation("CreatedPolls")
  pollRecipients       PollRecipient[]           @relation("PollRecipients")
  pollVotes            PollVote[]                @relation("PollVotes")
  createdEvents        Event[]                   @relation("CreatedEvents")
  eventRegistrations   EventRegistration[]       @relation("EventRegistrations")
  ownedRentals         RentalRecord[]            @relation("RentalOwner")
  tenantRentals        RentalRecord[]            @relation("RentalTenant")
  createdTasks         Task[]                    @relation("CreatedTasks")
  assignedTasks        TaskAssignee[]            @relation("TaskAssignees")
  taskComments         TaskComment[]             @relation("TaskComments")
  societyRulesCreated  SocietyRule[]             @relation("SocietyRuleCreator")
  createdAssets        Asset[]                   @relation("CreatedAssets")
  assetMaintenanceLogs AssetMaintenanceLog[]     @relation("AssetMaintenanceLogs")
  householdMembers     HouseholdMember[]

  registeredVehicles Vehicle[] @relation("RegisteredVehicles")
  updatedVehicles    Vehicle[] @relation("UpdatedVehicles")
  removedVehicles    Vehicle[] @relation("RemovedVehicles")
  vehicleAuditLogs   VehicleAuditLog[]

  @@map("users")
}

model HouseholdMember {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  relation  String   // SPOUSE, CHILD, FATHER, MOTHER, PARENT, SIBLING, OTHER
  age       Int?
  gender    String?  // MALE, FEMALE, OTHER
  phone     String?
  isAdult   Boolean  @default(true)
