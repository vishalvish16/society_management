/// Defines when a society's recurring/one-shot maintenance bills should be generated automatically.
/// The scheduler picks up schedules whose scheduledFor <= now and executedAt is null.
model MaintenanceBillSchedule {
  id        String  @id @default(uuid())
  societyId String
  society   Society @relation(fields: [societyId], references: [id], onDelete: Cascade)

  /// Month for which maintenance bills will be generated (stored as any date; service normalizes to month-start).
  billingMonth DateTime

  /// Exact date+time (server time / DB time) when generation should run.
  scheduledFor DateTime

  /// Default amount used for units without unit-specific maintenanceAmount.
  defaultAmount Decimal @db.Decimal(10, 2)

  /// Due date assigned to generated bills.
  dueDate DateTime

  isActive   Boolean   @default(true)
  lastRunAt  DateTime?
  executedAt DateTime?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([societyId, billingMonth])
  @@index([societyId, isActive])
  @@index([scheduledFor])
  @@map("maintenance_bill_schedules")
}

model Expense {
  id              String          @id @default(uuid())
  societyId       String
  society         Society         @relation(fields: [societyId], references: [id])
  submittedById   String
  category        ExpenseCategory
  title           String
  description     String?
  amount          Decimal         @db.Decimal(10, 2)
  gstAmount       Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal         @db.Decimal(10, 2)
  expenseDate     DateTime
  status          ExpenseStatus   @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  /// How the expense was paid (drives cash vs bank reports). Set on approval.
  paymentMethod   PaymentMethod?
  referenceId     String?         // Transaction ref, check number, etc.
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  submitter   User                @relation("SubmittedExpenses", fields: [submittedById], references: [id])
  approver    User?               @relation("ApprovedExpenses", fields: [approvedById], references: [id])
  attachments ExpenseAttachment[]

  @@index([societyId])
  @@map("expenses")
}

/// Manual cash/bank ledger entries (incl. cash↔bank transfers).
/// System-generated income/expense (bills, donations, approved expenses) are still stored in their own tables,
/// but reports will UNION them with these entries to produce cash/bank balances.
model LedgerEntry {
  id        String  @id @default(uuid())
  societyId String
  society   Society @relation(fields: [societyId], references: [id], onDelete: Cascade)

  /// Which ledger this entry affects.
  account   LedgerAccount
  /// IN increases the account, OUT decreases it.
  direction LedgerDirection
  amount    Decimal         @db.Decimal(10, 2)

  /// When money actually moved (not "createdAt").
  occurredAt  DateTime @default(now())
  description String?

  /// Links the two sides of a transfer (same id for CASH OUT + BANK IN, etc.)
  transferGroupId String?

  createdById String?
  createdBy   User?    @relation("LedgerEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([societyId, occurredAt])
  @@index([societyId, account, occurredAt])
  @@index([transferGroupId])
  @@map("ledger_entries")
}

model ExpenseAttachment {
