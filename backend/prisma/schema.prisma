// ── COMMUNICATION MODELS ──────────────────────────────────────────────────────

enum ChatRoomType {
  GROUP // Society-wide group chat
  DIRECT // 1:1 direct message
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  VOICE
}

// ── POLL / VOTING MODELS ──────────────────────────────────────────────────────

enum PollStatus {
  OPEN
  CLOSED
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventRegistrationStatus {
  REGISTERED
  CANCELLED
}

model ChatRoom {
  id        String           @id @default(uuid())
  societyId String
  society   Society          @relation(fields: [societyId], references: [id], onDelete: Cascade)
  type      ChatRoomType
  /// For GROUP: display name. For DIRECT: null.
  name      String?
  /// For DIRECT rooms: sorted "uuidA,uuidB" for uniqueness
  dmKey     String?          @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  ChatMessage[]
  members   ChatRoomMember[]

  @@index([societyId])
  @@map("chat_rooms")
}

model ChatRoomMember {
  id         String    @id @default(uuid())
  roomId     String
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation("ChatMemberships", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  isMuted    Boolean   @default(false)

  @@unique([roomId, userId])
  @@index([userId])
  @@map("chat_room_members")
}

model ChatMessage {
  id          String                  @id @default(uuid())
  roomId      String
  room        ChatRoom                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User                    @relation("SentMessages", fields: [senderId], references: [id])
  type        MessageType             @default(TEXT)
  body        String?
  duration    Int? // seconds, for VOICE
  deletedAt   DateTime?
  createdAt   DateTime                @default(now())
  attachments ChatMessageAttachment[]

  @@index([roomId])
  @@index([senderId])
  @@map("chat_messages")
}

model ChatMessageAttachment {
  id        String      @id @default(uuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  mimeType  String
  size      Int

  @@index([messageId])
  @@map("chat_message_attachments")
}

model Poll {
  id            String     @id @default(uuid())
  societyId     String
  society       Society    @relation(fields: [societyId], references: [id], onDelete: Cascade)
  createdById   String
  creator       User       @relation("CreatedPolls", fields: [createdById], references: [id])
  title         String
  description   String?
  status        PollStatus @default(OPEN)
  allowMultiple Boolean    @default(false)
  closesAt      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  options    PollOption[]
  recipients PollRecipient[]
  votes      PollVote[]

  @@index([societyId, status])
  @@index([createdById])
  @@map("polls")
}

model PollOption {
  id        String   @id @default(uuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  votes PollVote[]

  @@unique([pollId, sortOrder])
  @@index([pollId])
  @@map("poll_options")
}

model PollRecipient {
  id        String   @id @default(uuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("PollRecipients", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([pollId, userId])
  @@index([userId])
  @@map("poll_recipients")
}

model PollVote {
  id        String     @id @default(uuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation("PollVotes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  // Single-choice polls enforce one vote per user per poll.
  // For allowMultiple=true, backend can relax this at API level later (unique would need migration).
  @@unique([pollId, userId])
  @@index([pollId])
  @@index([optionId])
  @@index([userId])
  @@map("poll_votes")
}

// ── EVENT / REGISTRATION MODELS ─────────────────────────────────────────────

model Event {
  id                        String      @id @default(uuid())
  societyId                 String
  society                   Society     @relation(fields: [societyId], references: [id], onDelete: Cascade)
  createdById               String
  creator                   User        @relation("CreatedEvents", fields: [createdById], references: [id])
  title                     String
  description               String?
  startDate                 DateTime
  endDate                   DateTime
  location                  String
  rules                     String?
  organizerName             String
  organizerContact          String
  maxMembersPerRegistration Int         @default(5)
  maxTotalRegistrations     Int?
  status                    EventStatus @default(UPCOMING)
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  attachments   EventAttachment[]
  registrations EventRegistration[]

  @@index([societyId, status])
  @@index([createdById])
  @@map("events")
}

model EventAttachment {
  id         String   @id @default(uuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fileName   String
  fileType   String
  fileSize   Int
  fileUrl    String
  uploadedAt DateTime @default(now())

  @@index([eventId])
  @@map("event_attachments")
}

model EventRegistration {
  id          String                  @id @default(uuid())
  eventId     String
  event       Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User                    @relation("EventRegistrations", fields: [userId], references: [id], onDelete: Cascade)
  memberCount Int                     @default(1)
  notes       String?
  status      EventRegistrationStatus @default(REGISTERED)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_registrations")
}

// ── TASK MANAGEMENT MODELS ──────────────────────────────────────────────────

enum TaskStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String  @id @default(uuid())
  societyId   String
  society     Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  createdById String
  creator     User    @relation("CreatedTasks", fields: [createdById], references: [id])

  title       String
  description String?
  category    String // MAINTENANCE, HOUSEKEEPING, SECURITY, ADMINISTRATION, FINANCE, COMMON_AREA, OTHER
  subCategory String? // Depends on category (see subcategory map)
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(OPEN)

  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  completedAt DateTime?
  statusNote  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignees   TaskAssignee[]
  attachments TaskAttachment[]
  comments    TaskComment[]

  @@index([societyId, status])
  @@index([createdById])
  @@index([societyId, category])
  @@map("tasks")
}

model TaskAssignee {
  id     String @id @default(uuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("TaskAssignees", fields: [userId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model TaskAttachment {
  id         String   @id @default(uuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName   String
  fileType   String
  fileSize   Int
  fileUrl    String
  uploadedAt DateTime @default(now())

  @@index([taskId])
  @@map("task_attachments")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("TaskComments", fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
  @@map("task_comments")
}

// ── ASSET MANAGEMENT MODELS ─────────────────────────────────────────────

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  DISPOSED
  LOST
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

model Asset {
  id          String  @id @default(uuid())
  societyId   String
  society     Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  createdById String
  creator     User    @relation("CreatedAssets", fields: [createdById], references: [id])

  name        String
  category    String // FURNITURE, ELECTRONICS, PLUMBING, ELECTRICAL, SECURITY, FIRE_SAFETY, ELEVATOR, HVAC, GARDEN, SPORTS, CLEANING, OTHER
  assetTag    String? // unique barcode / QR / label e.g. AST-0001
  description String?
  location    String? // building / block / common-area name
  floor       String? // floor or level
  unitId      String? // link to specific unit if unit-level asset
  unit        Unit?   @relation(fields: [unitId], references: [id])

  vendor         String? // supplier / vendor name
  serialNumber   String?
  purchaseDate   DateTime? @db.Date
  purchasePrice  Decimal?  @db.Decimal(12, 2)
  warrantyExpiry DateTime? @db.Date

  condition AssetCondition @default(NEW)
  status    AssetStatus    @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments     AssetAttachment[]
  maintenanceLogs AssetMaintenanceLog[]

  @@unique([societyId, assetTag])
  @@index([societyId, status])
  @@index([societyId, category])
  @@index([unitId])
  @@map("assets")
}

model AssetAttachment {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  docType    String // PHOTO, INVOICE, WARRANTY, MANUAL, OTHER
  fileName   String
  fileType   String
  fileSize   Int
  fileUrl    String
  uploadedAt DateTime @default(now())

  @@index([assetId])
  @@map("asset_attachments")
}

model AssetMaintenanceLog {
  id          String   @id @default(uuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  loggedById  String
  loggedBy    User     @relation("AssetMaintenanceLogs", fields: [loggedById], references: [id])
  title       String
  description String?
  cost        Decimal? @db.Decimal(12, 2)
  performedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([assetId])
  @@map("asset_maintenance_logs")
}

/// Platform-wide settings managed only by SUPER_ADMIN.
/// Stored as key/value pairs so new settings can be added without schema changes.
/// Known keys:
///   visitor_qr_max_hrs  – maximum hours a visitor QR code can be valid (default 3)
model PlatformSetting {
  key       String   @id // e.g. "visitor_qr_max_hrs"
  value     String // stored as string; parse per key
  label     String // human-readable label shown in SA UI
  dataType  String   @default("number") // "number" | "boolean" | "string"
  updatedAt DateTime @updatedAt
  updatedBy String? // userId of last SA who changed it

  @@map("platform_settings")
}

model SocietyRule {
  id          String   @id @default(uuid())
  societyId   String
  society     Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String   @default("GENERAL") // GENERAL, PARKING, NOISE, PETS, MAINTENANCE, SECURITY, OTHER
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdById String
  createdBy   User     @relation("SocietyRuleCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([societyId, isActive])
  @@index([societyId, category])
  @@map("society_rules")
}
